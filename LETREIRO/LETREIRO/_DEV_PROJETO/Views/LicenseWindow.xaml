<Window x:Class="LetreiroDigital.Views.LicenseWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Ativação do Sistema" Height="540" Width="520"
    WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
    Background="#1E1E1E" WindowStyle="None" AllowsTransparency="True"
    BorderBrush="#444" BorderThickness="1">

    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#333" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="10,5" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center"
                                VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#555" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI" />
        </Style>
    </Window.Resources>

    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Margin="0,0,0,15">
            <StackPanel>
                <TextBlock Text="ATIVAÇÃO DO PRODUTO" Foreground="#FF3333" FontSize="20"
                    FontWeight="Bold" HorizontalAlignment="Center" />
                <TextBlock Text="Identifique-se para ativar sua licença" Foreground="#888"
                    FontSize="12" HorizontalAlignment="Center" Margin="0,5,0,0" />
            </StackPanel>
        </Border>

        <!-- Inputs Form -->
        <StackPanel Grid.Row="1" VerticalAlignment="Center">

            <TextBlock Text="NOME COMPLETO:" Foreground="#BBB" FontSize="11" Margin="0,0,0,4" />
            <TextBox x:Name="txtNome" Height="32" Background="#111" Foreground="White"
                BorderBrush="#333" Margin="0,0,0,12" VerticalContentAlignment="Center" Padding="5" />

            <TextBlock Text="RG OU CPF:" Foreground="#BBB" FontSize="11" Margin="0,0,0,4" />
            <TextBox x:Name="txtDocumento" Height="32" Background="#111" Foreground="White"
                BorderBrush="#333" Margin="0,0,0,12" VerticalContentAlignment="Center" Padding="5" />

            <TextBlock Text="CHAVE DE ACESSO:" Foreground="White" FontSize="11" FontWeight="Bold"
                Margin="0,0,0,4" />
            <TextBox x:Name="txtChave" Height="38" FontSize="16" VerticalContentAlignment="Center"
                Background="#111" Foreground="#00FF88" BorderBrush="#444" BorderThickness="1"
                Padding="8" FontWeight="Bold" />

            <!-- Botão obter chave -->
            <Button x:Name="btnObterChave" Margin="0,14,0,0" Height="42"
                Click="BtnObterChave_Click" Cursor="Hand"
                BorderThickness="0">
                <Button.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#1A3A2A" Offset="0" />
                        <GradientStop Color="#0F2A1E" Offset="1" />
                    </LinearGradientBrush>
                </Button.Background>
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="obterBorder" CornerRadius="6"
                            Background="{TemplateBinding Background}"
                            BorderBrush="#00CC66" BorderThickness="1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Width="32" Height="32"
                                    CornerRadius="4" Margin="8,0,0,0">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#00CC66" Offset="0" />
                                            <GradientStop Color="#00AA55" Offset="1" />
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <TextBlock Text="🔑" FontSize="16"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center" />
                                </Border>
                                <StackPanel Grid.Column="1" Margin="10,0" VerticalAlignment="Center">
                                    <TextBlock Text="Obtenha aqui sua chave de ativação"
                                        Foreground="#00FF88" FontWeight="SemiBold"
                                        FontSize="12" FontFamily="Segoe UI" />
                                    <TextBlock
                                        Text="Planos a partir de R$ 29/mês — pagamento seguro"
                                        Foreground="#3D8C5A" FontSize="10"
                                        FontFamily="Segoe UI" Margin="0,2,0,0" />
                                </StackPanel>
                                <TextBlock Grid.Column="2" Text="›" Foreground="#00CC66"
                                    FontSize="18" FontWeight="Bold" Margin="0,0,12,0"
                                    VerticalAlignment="Center" />
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="obterBorder" Property="BorderBrush"
                                    Value="#00FF88" />
                                <Setter TargetName="obterBorder" Property="Background">
                                    <Setter.Value>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                            <GradientStop Color="#1F4A32" Offset="0" />
                                            <GradientStop Color="#183A27" Offset="1" />
                                        </LinearGradientBrush>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <CheckBox x:Name="chkLGPD" Margin="0,15,0,0" VerticalAlignment="Center">
                <TextBlock
                    Text="Eu concordo com o processamento dos meus dados para fins de licenciamento (LGPD)."
                    Foreground="#888" FontSize="10" TextWrapping="Wrap" MaxWidth="400" />
            </CheckBox>
        </StackPanel>

        <!-- Status -->
        <TextBlock x:Name="lblStatus" Grid.Row="2" Text="" Foreground="#FFFF00"
            HorizontalAlignment="Center" VerticalAlignment="Center" TextWrapping="Wrap"
            Margin="0,10" FontSize="11" />

        <!-- Buttons -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right"
            Margin="0,10,0,0">
            <Button Content="SAIR" Width="100" Height="35" Click="BtnSair_Click"
                Background="#333" Foreground="#888" />
            <Button Content="ATIVAR AGORA" Width="140" Height="35" Click="BtnAtivar_Click"
                Background="#CC0000" FontWeight="Bold" Margin="10,0,0,0" />
        </StackPanel>
    </Grid>
</Window>